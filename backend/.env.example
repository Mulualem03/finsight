# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://finsight:finsight@localhost:5432/finsight?schema=public

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────────────
# IMPORTANT: generate per environment with `openssl rand -base64 64`
JWT_ACCESS_SECRET=replace-me-with-a-256-bit-secret
JWT_REFRESH_SECRET=replace-me-with-a-different-256-bit-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Token-at-rest encryption ──────────────────────────────────────────────
# 32 bytes, base64. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=YWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXpBQkNERUY=

# ─── Open Banking ──────────────────────────────────────────────────────────
# Either "truelayer" or "mock"
OPEN_BANKING_PROVIDER=mock

# Required if OPEN_BANKING_PROVIDER=truelayer
# https://console.truelayer.com/
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=http://localhost:5173/connect/callback
TRUELAYER_ENVIRONMENT=sandbox

# ─── Rate limiting ─────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
